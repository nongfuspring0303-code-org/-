{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FatigueCalculator Output",
  "description": "FatigueCalculator 输出契约：疲劳度结果与交易约束信息。",
  "type": "object",
  "required": [
    "event_id",
    "fatigue_category",
    "fatigue_tag",
    "fatigue_final",
    "watch_mode",
    "a_minus_1_discount_factor",
    "take_profit_penalty",
    "reset_eligible"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "fatigue_category": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fatigue_tag": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fatigue_final": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "watch_mode": {
      "type": "boolean"
    },
    "a_minus_1_discount_factor": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "take_profit_penalty": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reset_eligible": {
      "type": "boolean"
    },
    "reasoning": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ME-E-20260331-002.V1.0",
      "fatigue_category": 80,
      "fatigue_tag": 100,
      "fatigue_final": 100,
      "watch_mode": true,
      "a_minus_1_discount_factor": 0.5,
      "take_profit_penalty": 0.5,
      "reset_eligible": false,
      "reasoning": "类别第6次、标签第7次及以上，最终疲劳取最大值100"
    }
  ]
}
