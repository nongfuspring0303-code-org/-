{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifecycleManager Output",
  "description": "LifecycleManager 输出契约：生命周期状态、催化状态与交易准入建议。",
  "type": "object",
  "required": [
    "event_id",
    "lifecycle_state",
    "catalyst_state",
    "trade_eligibility",
    "holding_horizon",
    "transition_reason",
    "needs_manual_review"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["Detected", "Verified", "Active", "Continuation", "Exhaustion", "Dead", "Archived"]
    },
    "catalyst_state": {
      "type": "string",
      "enum": ["first_impulse", "continuation", "exhaustion", "dead"]
    },
    "trade_eligibility": {
      "type": "string",
      "enum": ["tradable", "watch", "blocked", "archive_only"]
    },
    "holding_horizon": {
      "type": "string",
      "enum": ["intraday", "overnight", "multiweek", "none"]
    },
    "transition_reason": {
      "type": "string"
    },
    "next_review_at": {
      "type": "string",
      "format": "date-time"
    },
    "needs_manual_review": {
      "type": "boolean"
    },
    "state_version": {
      "type": "string"
    },
    "reasoning": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ME-C-20260330-001.V1.0",
      "lifecycle_state": "Detected",
      "catalyst_state": "first_impulse",
      "trade_eligibility": "watch",
      "holding_horizon": "intraday",
      "transition_reason": "事件刚发现，尚未完成确认与市场验证",
      "needs_manual_review": false,
      "state_version": "lifecycle_v1"
    }
  ]
}
