{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Event Intel Output Schema",
  "description": "Output payload for AI event intelligence scoring.",
  "type": "object",
  "required": [
    "trace_id",
    "event_id",
    "evidence_score",
    "consistency_score",
    "freshness_score",
    "confidence",
    "narrative_state",
    "schema_version",
    "producer",
    "generated_at"
  ],
  "properties": {
    "trace_id": {"type": "string", "minLength": 8},
    "event_id": {"type": "string"},
    "evidence_score": {"type": "number", "minimum": 0, "maximum": 100},
    "consistency_score": {"type": "number", "minimum": 0, "maximum": 100},
    "freshness_score": {"type": "number", "minimum": 0, "maximum": 100},
    "confidence": {"type": "number", "minimum": 0, "maximum": 100},
    "narrative_state": {"type": "string", "enum": ["initial", "continuation", "decay", "invalid"]},
    "reasoning": {"type": "array", "items": {"type": "string"}},
    "schema_version": {"type": "string"},
    "producer": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
