{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SignalScorer Input",
  "description": "SignalScorer 输入契约：综合 A0/A-1/A1/A1.5/A0.5 与疲劳、相关性、政策干预，形成最终评分。",
  "type": "object",
  "required": [
    "event_id",
    "severity",
    "A0",
    "A-1",
    "A1",
    "A1.5",
    "A0.5",
    "fatigue_final",
    "correlation"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["E0", "E1", "E2", "E3", "E4"]
    },
    "A0": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "A-1": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "A1": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "A1.5": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "A0.5": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "fatigue_final": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "a_minus_1_discount_factor": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 1.0
    },
    "correlation": {
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "is_crowded": {
      "type": "boolean",
      "default": false
    },
    "narrative_mode": {
      "type": "string",
      "enum": ["Narrative-Driven", "Fact-Driven"]
    },
    "policy_intervention": {
      "type": "string",
      "enum": ["NONE", "WEAK", "MEDIUM", "STRONG"],
      "default": "NONE"
    },
    "base_direction": {
      "type": "string",
      "enum": ["long", "short", "neutral"],
      "default": "neutral"
    },
    "watch_mode": {
      "type": "boolean",
      "default": false
    },
    "weights_version": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "event_id": "ME-C-20260330-001.V1.0",
      "severity": "E3",
      "A0": 30,
      "A-1": 70,
      "A1": 78,
      "A1.5": 60,
      "A0.5": 0,
      "fatigue_final": 20,
      "a_minus_1_discount_factor": 1.0,
      "correlation": 0.4,
      "is_crowded": false,
      "narrative_mode": "Fact-Driven",
      "policy_intervention": "NONE",
      "base_direction": "long",
      "watch_mode": false,
      "weights_version": "score_v1"
    }
  ]
}
