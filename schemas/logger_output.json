{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Logger Output Schema",
  "description": "Structured logger output payload.",
  "type": "object",
  "required": ["timestamp", "level", "message"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR"]
    },
    "message": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "module": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
