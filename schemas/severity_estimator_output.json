{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SeverityEstimator Output",
  "description": "Output contract for severity level and mapped A0 baseline score.",
  "type": "object",
  "required": ["severity", "A0"],
  "properties": {
    "severity": {
      "type": "string",
      "enum": ["E0", "E1", "E2", "E3", "E4"]
    },
    "A0": {
      "type": "number",
      "enum": [0, 10, 20, 30, 40]
    }
  },
  "additionalProperties": false
}
