{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Logger Input Schema",
  "description": "Structured logger input payload.",
  "type": "object",
  "required": ["level", "message"],
  "properties": {
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARN", "ERROR"]
    },
    "message": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string"
    },
    "context": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
