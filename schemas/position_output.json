{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PositionSizer Output",
  "description": "Output contract for position sizing.",
  "type": "object",
  "required": [
    "score_tier",
    "base_position_pct",
    "final_position_pct",
    "final_notional",
    "liquidity_adjustment"
  ],
  "properties": {
    "score_tier": {
      "type": "string",
      "enum": ["G1", "G2", "G3", "G4", "G5"]
    },
    "base_position_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "final_position_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "final_notional": {
      "type": "number",
      "minimum": 0
    },
    "liquidity_adjustment": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
