{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SeverityEstimator Input",
  "description": "Input contract for severity estimation from market stress metrics.",
  "type": "object",
  "required": ["vix", "vix_change_pct", "spx_move_pct", "sector_move_pct"],
  "properties": {
    "vix": {
      "type": "number",
      "minimum": 0
    },
    "vix_change_pct": {
      "type": "number"
    },
    "spx_move_pct": {
      "type": "number"
    },
    "sector_move_pct": {
      "type": "number"
    }
  },
  "additionalProperties": false
}
