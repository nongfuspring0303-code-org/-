{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Decision Card Schema",
  "description": "Standard decision card generated by AI layer for downstream strategy/risk/orchestration.",
  "type": "object",
  "required": [
    "trace_id",
    "event_id",
    "summary",
    "evidence",
    "counter_evidence",
    "risk_notes",
    "trigger_conditions",
    "invalid_conditions",
    "schema_version",
    "producer",
    "generated_at"
  ],
  "properties": {
    "trace_id": {"type": "string", "minLength": 8},
    "event_id": {"type": "string"},
    "summary": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "counter_evidence": {"type": "array", "items": {"type": "string"}},
    "risk_notes": {"type": "array", "items": {"type": "string"}},
    "trigger_conditions": {"type": "array", "items": {"type": "string"}},
    "invalid_conditions": {"type": "array", "items": {"type": "string"}},
    "schema_version": {"type": "string"},
    "producer": {"type": "string"},
    "generated_at": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
